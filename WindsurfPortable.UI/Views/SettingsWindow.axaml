<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WindsurfPortable.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="520"
        x:Class="WindsurfPortable.UI.Views.SettingsWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Settings"
        Width="560" Height="520"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/WindsurfPortable.ico"
        Background="Transparent"
        SystemDecorations="BorderOnly"
        TransparencyLevelHint="Mica, AcrylicBlur, Blur">

  <Grid RowDefinitions="Auto,Auto,*">
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="20,16,20,10" ColumnSpacing="12">
      <Image Grid.Column="0" Width="18" Height="18" Source="/Assets/WindsurfPortable.png" />
      <StackPanel Grid.Column="1" Spacing="0">
        <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" />
        <TextBlock Text="Windsurf Portable" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
      </StackPanel>
      <Button Grid.Column="2" Content="Close" Classes="Ghost" Click="OnClose" />
    </Grid>

    <Border Grid.Row="1" Height="1" Background="{DynamicResource SystemControlForegroundChromeLowBrush}" Margin="20,0,20,0" />

    <ScrollViewer Grid.Row="2">
      <StackPanel Spacing="14" Margin="20,14,20,20">
        <Border Background="#30FC8181" CornerRadius="8" Padding="10">
          <TextBlock Text="Disabling patches can cause Windsurf to write to global folders." TextWrapping="Wrap" />
        </Border>

        <TextBlock Text="Patches" FontWeight="SemiBold" FontSize="14" />
        <Border Classes="Card" Padding="20">
          <StackPanel>
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto" ColumnSpacing="16" Margin="0,0,0,0">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Single instance" FontWeight="SemiBold" />
                <TextBlock Text="Allows multiple Windsurf instances." TextWrapping="Wrap" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12" />
              </StackPanel>
              <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding EnableSingleInstancePatch}" />
            </Grid>

            <Border Height="1" Background="{DynamicResource SystemControlForegroundChromeLowBrush}" Margin="0,12,0,12" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="MCP sync isolation" FontWeight="SemiBold" />
                <TextBlock Text="Prevents cross-profile synchronization." TextWrapping="Wrap" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12" />
              </StackPanel>
              <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding EnableMcpSyncIsolation}" />
            </Grid>

            <Border Height="1" Background="{DynamicResource SystemControlForegroundChromeLowBrush}" Margin="0,12,0,12" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Global recents" FontWeight="SemiBold" />
                <TextBlock Text="Avoid writing recent files to global state." TextWrapping="Wrap" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12" />
              </StackPanel>
              <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding EnableGlobalRecentsPatch}" />
            </Grid>
          </StackPanel>
        </Border>

        <TextBlock Text="Startup" FontWeight="SemiBold" FontSize="14" />
        <Border Classes="Card" Padding="20">
          <StackPanel>
            <Grid ColumnDefinitions="*,220" ColumnSpacing="16">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Default profile" FontWeight="SemiBold" />
                <TextBlock Text="Used by tray menu and auto-start." TextWrapping="Wrap" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12" />
              </StackPanel>
              <ComboBox Grid.Column="1" ItemsSource="{Binding Profiles}" SelectedItem="{Binding DefaultProfile}" />
            </Grid>

            <Border Height="1" Background="{DynamicResource SystemControlForegroundChromeLowBrush}" Margin="0,12,0,12" />

            <Grid ColumnDefinitions="*,220" ColumnSpacing="16">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Auto-hide" FontWeight="SemiBold" />
                <TextBlock Text="When the window should hide to tray after launch." TextWrapping="Wrap" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12" />
              </StackPanel>
              <ComboBox Grid.Column="1" ItemsSource="{Binding AutoHideOptions}" SelectedItem="{Binding AutoHideMode}" />
            </Grid>

            <Border Height="1" Background="{DynamicResource SystemControlForegroundChromeLowBrush}" Margin="0,12,0,12" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Auto-start" FontWeight="SemiBold" />
                <TextBlock Text="Start the default profile directly into tray." TextWrapping="Wrap" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12" />
              </StackPanel>
              <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding AutoStartDefaultProfile}" />
            </Grid>
          </StackPanel>
        </Border>

        <TextBlock Text="Updates" FontWeight="SemiBold" FontSize="14" />
        <Border Classes="Card" Padding="20">
          <StackPanel>
            <StackPanel Spacing="2">
              <TextBlock Text="Launcher updates" FontWeight="SemiBold" />
              <TextBlock Text="Uses GitHub Releases (Velopack)." TextWrapping="Wrap" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12" />
            </StackPanel>

            <Button Margin="0,12,0,0" Content="Open GitHub" Classes="Secondary" Command="{Binding OpenGitHubCommand}" />

            <TextBox Margin="0,12,0,0"
                     Watermark="https://github.com/owner/repo"
                     Text="{Binding LauncherUpdateRepoUrl}" />

            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
              <Button Content="Check" Command="{Binding CheckLauncherUpdatesCommand}" />
              <Button Content="Apply &amp; Restart"
                      Command="{Binding ApplyLauncherUpdateCommand}"
                      IsEnabled="{Binding IsLauncherUpdateAvailable}" />
            </StackPanel>

            <Border Height="1" Background="{DynamicResource SystemControlForegroundChromeLowBrush}" Margin="0,12,0,12" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Desktop shortcut" FontWeight="SemiBold" />
                <TextBlock Text="Create a desktop shortcut for the launcher." TextWrapping="Wrap" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12" />
              </StackPanel>
              <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding EnableLauncherDesktopShortcut}" />
            </Grid>

            <Border Height="1" Background="{DynamicResource SystemControlForegroundChromeLowBrush}" Margin="0,12,0,12" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Start with Windows" FontWeight="SemiBold" />
                <TextBlock Text="Add the launcher to the Startup folder." TextWrapping="Wrap" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12" />
              </StackPanel>
              <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding EnableLauncherStartupShortcut}" />
            </Grid>

            <TextBlock Margin="0,12,0,0" Text="{Binding LauncherUpdateMessage}" TextWrapping="Wrap" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WindsurfPortable.UI.ViewModels"
        xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="WindsurfPortable.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Windsurf Portable Launcher"
        Width="600" Height="400"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/WindsurfPortable.ico"
        Background="Transparent"
        TransparencyLevelHint="Mica, AcrylicBlur, Blur">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" Margin="20" RowSpacing="14">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0,0,0,6" Background="Transparent" PointerPressed="OnHeaderPointerPressed">
            <Grid Grid.Column="0" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Image Grid.Column="0" Width="32" Height="32" Source="/Assets/WindsurfPortable.png" />
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="Windsurf Portable" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="Profile-isolated launcher" Classes="muted" FontSize="12" />
                </StackPanel>
            </Grid>
            <Button Grid.Column="1" Content="Settings" Classes="Ghost" Click="OnOpenSettings" VerticalAlignment="Center"
                    IsVisible="{Binding !IsForwardedInvocationMode}" />
        </Grid>

        <Border Grid.Row="1" IsVisible="{Binding IsWindsurfMissing}" Classes="Card" Padding="20">
            <StackPanel Spacing="14" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                <TextBlock Text="Windsurf installation not found" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
                <TextBlock Text="Download an initial version to continue." TextWrapping="Wrap" HorizontalAlignment="Center" Classes="muted" />

                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                    <Button Content="Download Stable" Command="{Binding DownloadInitialCommand}" CommandParameter="stable" Classes="Primary" />
                    <Button Content="Download Next" Command="{Binding DownloadInitialCommand}" CommandParameter="next" Classes="Secondary" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" IsVisible="{Binding !IsWindsurfMissing}" Classes="Card" Padding="20">
            <StackPanel Spacing="12">
                <TextBlock Text="Profile" FontWeight="SemiBold" />

                <ComboBox ItemsSource="{Binding Profiles}"
                          SelectedItem="{Binding SelectedProfile}"
                          HorizontalAlignment="Stretch" />

                <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding !IsForwardedInvocationMode}">
                    <Button Content="Create Profile" Command="{Binding CreateProfileCommand}" Classes="Secondary" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,4,0,0">
            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                       VerticalAlignment="Center" Classes="muted" TextWrapping="Wrap" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                <Button Content="Debug banners" Command="{Binding DebugCycleBannersCommand}" Classes="Secondary"
                        IsVisible="{Binding ShowDebugBanners}" />
                <Button Content="Launch" Command="{Binding LaunchCommand}" Classes="Primary" FontWeight="SemiBold" />
            </StackPanel>
        </Grid>

        <Border Grid.RowSpan="3" ZIndex="15" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Margin="20" Background="Transparent"
                IsVisible="{Binding IsUpdateOverlayVisible}">
            <Border Background="#E609090B" BorderBrush="#27272A" BorderThickness="1" Padding="16" CornerRadius="8" BoxShadow="0 4 6 -1 #A6000000, 0 2 4 -2 #A6000000">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16" VerticalAlignment="Center">
                    <TextBlock Grid.Column="0" Text="{Binding UpdateOverlayMessage}" VerticalAlignment="Center" FontWeight="Medium" TextWrapping="Wrap" Foreground="#FAFAFA" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Content="Dismiss" Command="{Binding DismissUpdateOverlayCommand}" Classes="Ghost" Foreground="#A1A1AA" />

                        <Button Content="Restart" Command="{Binding RestartToApplyLauncherUpdateCommand}"
                                IsVisible="{Binding ShowLauncherRestartButton}" Background="#FAFAFA" Foreground="#09090B" FontWeight="Medium" CornerRadius="6" />

                        <Button Command="{Binding ApplyUpdateCommand}"
                                IsVisible="{Binding ShowWindsurfUpdateButtons}" Background="#FAFAFA" Foreground="#09090B" FontWeight="Medium" CornerRadius="6">
                            <TextBlock Text="Update &amp; Restart" />
                        </Button>

                        <Button Content="Skip" Command="{Binding SkipUpdateCommand}" Classes="Ghost"
                                IsVisible="{Binding ShowWindsurfUpdateButtons}" Foreground="#A1A1AA" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <shadui:DialogHost Manager="{Binding DialogManager}" Grid.RowSpan="3" ZIndex="18" />

        <Panel Grid.RowSpan="3" IsVisible="{Binding IsBusy}" ZIndex="20" Margin="-20">
            <!-- Background darkener/blur -->
            <Border Background="#A6000000" />
            
            <!-- The Card -->
            <Border Background="#E609090B" BorderBrush="#27272A" BorderThickness="1" CornerRadius="8" BoxShadow="0 4 6 -1 #A6000000, 0 2 4 -2 #A6000000"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Width="360" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="Working…" FontWeight="SemiBold" FontSize="18" Foreground="#FAFAFA" />
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#A1A1AA" FontSize="14" />
                    <ProgressBar IsIndeterminate="True" Height="6" CornerRadius="3" Foreground="#FAFAFA" Background="#27272A" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </Panel>
    </Grid>

</Window>
